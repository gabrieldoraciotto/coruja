# Banco de dados Postgres (o Railway gera essa URL automaticamente)
DATABASE_URL="postgresql://usuario:senha@host:5432/railway"

# ── Provedor de IA (compatível com OpenAI) ────────────────────────────────
# Chave do provedor escolhido
AI_API_KEY="sua-chave-aqui"

# --- Opção GEMINI (Google AI Studio): https://aistudio.google.com/apikey ---
AI_BASE_URL="https://generativelanguage.googleapis.com/v1beta/openai/"
WRITER_MODEL="gemini-2.5-flash"
TRIAGE_MODEL="gemini-2.5-flash-lite"

# --- Opção GROQ: https://console.groq.com/keys (descomente para usar) ---
# AI_BASE_URL="https://api.groq.com/openai/v1"
# WRITER_MODEL="llama-3.3-70b-versatile"
# TRIAGE_MODEL="llama-3.1-8b-instant"

# Cadência do calendário (0=dom ... 6=sáb). Padrão 1,3,5 = seg, qua, sex
CADENCE_DAYS="1,3,5"
WEEKS_AHEAD="4"
RELEVANCE_THRESHOLD="60"

PORT="3333"
