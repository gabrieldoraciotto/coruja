# ── Banco de dados (PostgreSQL) ─────────────────────────────────────────────
DATABASE_URL=postgresql://usuario:senha@localhost:5432/coruja

# ── IA — qualquer provedor compatível com a API da OpenAI ──────────────────
# Groq (usado na demo): https://console.groq.com
AI_API_KEY=sua-chave-aqui
AI_BASE_URL=https://api.groq.com/openai/v1
TRIAGE_MODEL=llama-3.1-8b-instant
WRITER_MODEL=llama-3.3-70b-versatile

# ── Comportamento ───────────────────────────────────────────────────────────
# Nota mínima (0-100) para uma notícia entrar em "Relevantes"
RELEVANCE_THRESHOLD=60
# Tema padrão do canal (o visitante pode trocar na tela de Temas)
DEFAULT_NICHE=tecnologia e inteligência artificial
# Teto diário de gerações de roteiro do playground
DAILY_GENERATION_LIMIT=40
PORT=3333

# ── Opcionais ───────────────────────────────────────────────────────────────
# Protege a API com senha única (clientes enviam o header x-app-key)
# APP_PASSWORD=
# Lembretes diários por e-mail via Resend (herdados do projeto de origem)
# RESEND_API_KEY=
# REMINDER_FROM=
# REMINDER_TO=
# APP_URL=
